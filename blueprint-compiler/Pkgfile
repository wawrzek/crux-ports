# Description: Markup language and compiler for GTK 4 user interfaces
# URL: https://jwestman.pages.gitlab.gnome.org/blueprint-compiler/
# Maintainer: Wawrzek Niewodniczanski, main at wawrzek dot name
# Packager: Jay Lanagan, j at lngn dot net
# Depends on: libadwaita python3-gobject

name=blueprint-compiler
version=0.20.4
release=1
source=(https://download.gnome.org/sources/$name/${version%.*}/$name-$version.tar.xz)

build() {

  meson setup $name-$version build \
    --prefix=/usr \
    --sysconfdir=/etc \
    --buildtype=release \
    --wrap-mode=nofallback \
    -Db_lto=true \
    -Db_pie=true \
    -Dstrip=true

  meson compile -C build
  DESTDIR=$PKG meson install -C build

}
